# Estacionamento — variáveis do docker-compose (Postgres + MinIO compartilhados no stack feedback).
# cp .env.example .env
# docker compose --env-file .env up -d --build
#
# Portas no host: frontend 3084, backend 3085

# --- PostgreSQL (instância feedback, banco dedicado) ---
POSTGRES_USER=feedback_user
POSTGRES_PASSWORD=feedback_pass
POSTGRES_DB=estacionamento_db

# --- MinIO (instância feedback, bucket dedicado) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=estacionamento-files

# Nest, JWT, CORS, e-mail, IA: ver backend/.env.example
# REACT_APP_API_URL: ver frontend/.env.example
